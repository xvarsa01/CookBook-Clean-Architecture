<?xml version="1.0" encoding="utf-8" ?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:texts="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Resources.Texts"
             x:Class="CookBook.CleanArch.Presentation.MauiApplication.Controls.Ingredients.IngredientImageFilterControl"
             x:Name="Root">

    <VerticalStackLayout Spacing="10">
        <Label FontSize="12"
               Text="{x:Static texts:IngredientListViewTexts.Image_Title_Text}" />
        <Picker x:Name="ImagePicker"
                SelectedItem="{Binding  Source={x:Reference Root}, Path=HasImage, Converter={StaticResource NullableBoolToStringConverter}}">
            <Picker.ItemsSource>
                <x:Array Type="{x:Type x:String}">
                    <x:String>-</x:String>
                    <x:String>Yes</x:String>
                    <x:String>No</x:String>
                </x:Array>
            </Picker.ItemsSource>
        </Picker>
    </VerticalStackLayout>
</ContentView>



