<?xml version="1.0" encoding="utf-8" ?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:texts="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Resources.Texts"
             x:Class="CookBook.CleanArch.Presentation.MauiApplication.Controls.Ingredients.IngredientSearchControl"
             x:Name="Root">

    <VerticalStackLayout Spacing="10"
                         WidthRequest="250">
        <Label FontSize="12"
               Text="{x:Static texts:IngredientListViewTexts.Search_Title_Text}" />
        <SearchBar Placeholder="{x:Static texts:IngredientListViewTexts.Search_Placeholder_Text}"
                   Text="{Binding Source={x:Reference Root}, Path=SearchText, Mode=TwoWay}" />
    </VerticalStackLayout>
</ContentView>

