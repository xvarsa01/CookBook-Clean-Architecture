<?xml version="1.0" encoding="utf-8" ?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="using:CookBook.CleanArch.Presentation.MauiApplication.Helpers"
             x:Class="CookBook.CleanArch.Presentation.MauiApplication.Controls.Ingredients.IngredientHasImagePickerControl"
             x:Name="Root">

    <VerticalStackLayout Spacing="10">
        <Label FontSize="12"
               Text="{helpers:DynamicTranslate LocalizationManager={StaticResource IngredientsControlsLocalizationManager}, Text=HasImageFilter_Title_Text}" />
        <Picker ItemsSource="{Binding Source={x:Reference Root}, Path=Options}"
                SelectedItem="{Binding Source={x:Reference Root}, Path=HasImage}">
            <Picker.ItemDisplayBinding>
                <Binding Converter="{StaticResource LocalizedNullableBoolConverter}"
                         ConverterParameter="{StaticResource IngredientsControlsLocalizationManager}" />
            </Picker.ItemDisplayBinding>
        </Picker>
    </VerticalStackLayout>
</ContentView>
