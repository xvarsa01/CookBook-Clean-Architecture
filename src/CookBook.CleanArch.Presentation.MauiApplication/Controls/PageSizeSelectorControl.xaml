<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
             xmlns:inputKit="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
             xmlns:texts="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Resources.Texts"
             x:Class="CookBook.CleanArch.Presentation.MauiApplication.Controls.PageSizeSelectorControl"
             x:Name="Root">
    
    <VerticalStackLayout Spacing="10">
        <Label Text="{x:Static texts:ControlTexts.PageSize_Title_Text}" />
        <controls:RadioButtonGroupView SelectedItem="{Binding Source={x:Reference Root}, Path=SelectedPageSize, Mode=TwoWay}">
            <inputKit:RadioButton Text="5"
                                  Value="{x:Int32 5}" />
            <inputKit:RadioButton Text="10"
                                  Value="{x:Int32 10}" />
            <inputKit:RadioButton Text="15"
                                  Value="{x:Int32 15}" />
        </controls:RadioButtonGroupView>
    </VerticalStackLayout>
</ContentView>
