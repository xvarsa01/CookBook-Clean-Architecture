<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:inputKit="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
             xmlns:helpers="using:CookBook.CleanArch.Presentation.MauiApplication.Helpers"
             x:Class="CookBook.CleanArch.Presentation.MauiApplication.Controls.Shared.SortDirectionControl"
             x:Name="Root">
    
    <VerticalStackLayout Spacing="10">
        <Label FontSize="12"
               Text="{helpers:DynamicTranslate LocalizationManager={StaticResource ControlsLocalizationManager}, Text=SortDirection_Title_Text}" />
        <inputKit:RadioButtonGroupView>
            <inputKit:RadioButton IsChecked="{Binding Source={x:Reference Root}, Path=IsSortAscending}"
                                  Text="{helpers:DynamicTranslate LocalizationManager={StaticResource ControlsLocalizationManager}, Text=Sort_AscOption_Text}" />
            <inputKit:RadioButton IsChecked="{Binding Source={x:Reference Root}, Path=IsSortAscending, Converter={StaticResource InverseBooleanConverter}}"
                                  Text="{helpers:DynamicTranslate LocalizationManager={StaticResource ControlsLocalizationManager}, Text=Sort_DescOption_Text}" />
        </inputKit:RadioButtonGroupView>
    </VerticalStackLayout>
</ContentView>
