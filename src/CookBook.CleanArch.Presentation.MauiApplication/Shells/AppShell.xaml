<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:r="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Views.Recipe"
       xmlns:s="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Views"
       xmlns:i="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Views.Ingredient"
       xmlns:helpers="using:CookBook.CleanArch.Presentation.MauiApplication.Helpers"
       x:Class="CookBook.CleanArch.Presentation.MauiApplication.Shells.AppShell"
       x:Name="AppShellRoot"
       ForegroundColor="{DynamicResource ShellBackButtonColorColor}"
       FlyoutBehavior="Disabled">
    <Shell.MenuBarItems>
        <MenuBarItem Text="{helpers:DynamicTranslate LocalizationManager={StaticResource AppShellLocalizationManager}, Text=File_MenuItem_Title}">
            <MenuFlyoutItem Text="{helpers:DynamicTranslate LocalizationManager={StaticResource AppShellLocalizationManager}, Text=Recipes_Tab_Title}"
                            Command="{Binding Source={x:Reference AppShellRoot}, Path=GoToRecipesCommand}" />

            <MenuFlyoutItem Text="{helpers:DynamicTranslate LocalizationManager={StaticResource AppShellLocalizationManager}, Text=Ingredients_Tab_Title}"
                            Command="{Binding Source={x:Reference AppShellRoot}, Path=GoToIngredientsCommand}" />
            
            <MenuFlyoutItem Text="{helpers:DynamicTranslate LocalizationManager={StaticResource AppShellLocalizationManager}, Text=Settings_Tab_Title}"
                            Command="{Binding Source={x:Reference AppShellRoot}, Path=GoToSettingsCommand}" />
        </MenuBarItem>
    </Shell.MenuBarItems>

    <ShellContent ContentTemplate="{DataTemplate r:RecipeListView}" Route="recipes" />
    <ShellContent ContentTemplate="{DataTemplate i:IngredientListView}" Route="ingredients" />
    <ShellContent ContentTemplate="{DataTemplate s:SettingsView }" Route="settings" />
</Shell>
