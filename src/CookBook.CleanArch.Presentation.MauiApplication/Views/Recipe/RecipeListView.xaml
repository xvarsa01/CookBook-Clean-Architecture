<?xml version="1.0" encoding="utf-8" ?>
<views:ContentPageBase xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                       xmlns:views="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Views"
                       xmlns:viewModels="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.ViewModels"
                       xmlns:recipeControls="using:CookBook.CleanArch.Presentation.MauiApplication.Controls.Recipe"
                       xmlns:models="using:CookBook.CleanArch.Application.Recipes.Models"
                       xmlns:shared="using:CookBook.CleanArch.Presentation.MauiApplication.Controls.Shared"
                       xmlns:helpers="using:CookBook.CleanArch.Presentation.MauiApplication.Helpers"
                       x:Class="CookBook.CleanArch.Presentation.MauiApplication.Views.Recipe.RecipeListView"
                       Title="{helpers:DynamicTranslate LocalizationManager={StaticResource RecipeListLocalizationManager}, Text=Page_Title}"
                       x:DataType="viewModels:RecipeListViewModel"
                       x:Name="RecipeListViewRoot"
                       Style="{StaticResource ContentPageStyle}">
    <Grid HorizontalOptions="Fill"
          RowDefinitions="Auto, *, Auto"
          RowSpacing="20"
          Margin="{OnIdiom Phone='10, 0'}">
        
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto, *, Auto">

            <!--  Title  -->
            <Label Grid.Column="0"
                   FontSize="24"
                   Text="{helpers:DynamicTranslate LocalizationManager={StaticResource RecipeListLocalizationManager}, Text=Title_Label}" />

            <HorizontalStackLayout Grid.Column="2" Spacing="20">

                <recipeControls:RecipeSearchControl SearchText="{Binding Filter.Name, Mode=TwoWay}" />

                <recipeControls:RecipeTypePickerControl SelectedRecipeType="{Binding Filter.RecipeType, Mode=TwoWay}" />

                <recipeControls:RecipeMinimalDurationPickerControl UsePicker="{Binding UseMinimalDuration, Mode=TwoWay}"
                                                                   SelectedValue="{Binding MinimalDuration, Mode=TwoWay}"/>
                
                <recipeControls:RecipeMaximalDurationPickerControl UsePicker="{Binding UseMaximalDuration, Mode=TwoWay}"
                                                                   SelectedValue="{Binding MaximalDuration, Mode=TwoWay}"/>
                
                <shared:SortDirectionControl IsSortAscending="{Binding Filter.IsSortAscending, Mode=TwoWay}" />
                
                <shared:PageSizeSelectorControl SelectedPageSize="{Binding PagingOptions.PageSize, Mode=TwoWay}"/>

                <shared:ApplyFilterButton ApplyCommand="{Binding ApplyFilterCommand}" />
            </HorizontalStackLayout>
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Recipes}"
                        VerticalOptions="Fill">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Horizontal"
                                 HorizontalItemSpacing="10" VerticalItemSpacing="10"
                                 Span="2" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:RecipeListResponse">
                    <Border Padding="0"
                            WidthRequest="300" HeightRequest="200">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:Reference RecipeListViewRoot}, Path=BindingContext.GoToDetailCommand}"
                                                  CommandParameter="{Binding Id}" />
                        </Border.GestureRecognizers>

                        <Grid>
                            <Image Grid.Row="0"
                                   HorizontalOptions="Fill" VerticalOptions="Fill"
                                   Aspect="AspectFill"
                                   WidthRequest="320" HeightRequest="240"
                                   Source="{Binding ImageUrl.Value, TargetNullValue='recipe_placeholder.jpg'}" />

                            <BoxView Grid.Row="0"
                                     Opacity="0.25"
                                     Color="Black" />

                            <Border Grid.Row="0"
                                    Margin="22" Padding="6,0"
                                    BackgroundColor="{Binding RecipeType, Converter={StaticResource FoodTypeToColorConverter}}"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Start"
                                    HeightRequest="20">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="5"/>
                                </Border.StrokeShape>
                                
                                <HorizontalStackLayout Padding="0"
                                                       HorizontalOptions="Start" VerticalOptions="Center"
                                                       Spacing="8">
                                    <Label VerticalOptions="Center"
                                           FontSize="11"
                                           Text="{Binding RecipeType, Converter={StaticResource FoodTypeToStringConverter}}"
                                           TextColor="White" />
                                </HorizontalStackLayout>
                            </Border>

                            <Label Grid.Row="0"
                                   Margin="22,12"
                                   FontSize="20" LineBreakMode="WordWrap"
                                   Text="{Binding Name.Value}"
                                   TextColor="White" VerticalOptions="End" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <Grid Grid.Row="2">
            <Button Margin="10,0"
                    Padding="12,6"
                    HorizontalOptions="Start"
                    Text="{helpers:DynamicTranslate LocalizationManager={StaticResource RecipeListLocalizationManager}, Text=Add_Button_Text}"
                    Command="{Binding GoToCreateCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    WidthRequest="300" />

            <shared:PagerControl ToFirstCommand="{Binding ToFirstPageCommand}"
                                   ToNextCommandCommand="{Binding ToNextPageCommand}"
                                   ToPreviousCommand="{Binding ToPreviousPageCommand}"
                                   ToLastCommandCommand="{Binding ToLastPageCommand}"
                                   PageNumbers="{Binding PageNumbers}"
                                   GoToPageCommand="{Binding GoToPageCommand}" />
        </Grid>
    </Grid>
</views:ContentPageBase>
