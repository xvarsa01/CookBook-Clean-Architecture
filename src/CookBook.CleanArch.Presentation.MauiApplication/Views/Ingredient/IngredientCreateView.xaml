<?xml version="1.0" encoding="utf-8"?>

<views:ContentPageBase xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                       xmlns:views="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Views"
                       xmlns:viewModels="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.ViewModels"
                       xmlns:ingredients="using:CookBook.CleanArch.Presentation.MauiApplication.Controls.Ingredients"
                       x:Class="CookBook.CleanArch.Presentation.MauiApplication.Views.Ingredient.IngredientCreateView"
                       x:DataType="viewModels:IngredientCreateViewModel"
                       Style="{StaticResource ContentPageStyle}">

    <ingredients:IngredientCreateEditBaseView
        Ingredient="{Binding Ingredient}"
        SaveCommand="{Binding SaveCommand}"
        ValidatePropertyCommand="{Binding ValidatePropertyCommand}"/>

</views:ContentPageBase>
