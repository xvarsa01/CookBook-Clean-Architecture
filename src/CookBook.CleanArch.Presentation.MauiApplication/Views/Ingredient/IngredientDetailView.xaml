<?xml version="1.0" encoding="utf-8" ?>
<views:ContentPageBase xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                       xmlns:views="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Views"
                       xmlns:xaml="clr-namespace:Microsoft.Maui.Controls.Xaml;assembly=Microsoft.Maui.Controls.Xaml"
                       xmlns:texts="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Resources.Texts"
                       xmlns:viewModels="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.ViewModels"
                       xmlns:models="using:CookBook.CleanArch.Application.Recipes.Models"
                       xmlns:rs="using:CookBook.CleanArch.Presentation.MauiApplication.Resources.Fonts"
                       x:Class="CookBook.CleanArch.Presentation.MauiApplication.Views.Ingredient.IngredientDetailView"
                       Title="{xaml:Static texts:IngredientDetailViewTexts.Page_Title}"
                       Style="{StaticResource ContentPageStyle}"
                       x:Name="IngredientDetailViewRoot"
                       x:DataType="viewModels:IngredientDetailViewModel">
    <VerticalStackLayout Spacing="20">
        <Grid>
            <Grid HorizontalOptions="Center" VerticalOptions="Start"
                  ColumnDefinitions="*, Auto, Auto, *"
                  ColumnSpacing="20">

                <Border Grid.Column="1"
                        HorizontalOptions="Center" VerticalOptions="Center"
                        Style="{StaticResource ImageBorderStyle}">
                    <Image Aspect="AspectFill"
                           WidthRequest="170" HeightRequest="170"
                           Source="{Binding Ingredient.ImageUrl.Value, TargetNullValue='ingredient_placeholder.jpg'}"/>
                </Border>

                <VerticalStackLayout Grid.Column="2"
                                     Spacing="20">
                    <Label FontSize="24" 
                           Text="{Binding Ingredient.Name}" />

                    <Label FontSize="14" 
                           Text="{Binding Ingredient.Description}"/>
                </VerticalStackLayout>
            </Grid>
            <HorizontalStackLayout HorizontalOptions="End"
                                   VerticalOptions="Start"
                                   Spacing="15"
                                   HeightRequest="30">
                <Button FontFamily="{x:Static rs:FontKeys.IconsFont}"
                        Text="{x:Static rs:IconKeys.Delete}"
                        CornerRadius="5"
                        BackgroundColor="{StaticResource ErrorColor}"
                        Command="{Binding DeleteCommand}" />

                <Button FontFamily="{x:Static rs:FontKeys.IconsFont}"
                        Text="{x:Static rs:IconKeys.Edit}"
                        CornerRadius="5"
                        BackgroundColor="{StaticResource PrimaryColor}"
                        Command="{Binding GoToEditCommand}" />
            </HorizontalStackLayout>            
        </Grid>
        
        <Label Text="{x:Static texts:IngredientDetailViewTexts.UsedInFollowingRecipes_CollectionTitle_Text}"
               IsVisible="{Binding RecipesUsingIngredient.Count, Converter={StaticResource IsCountNotZeroConverter}}"/>
        
        <Label Text="{x:Static texts:IngredientDetailViewTexts.NotUsedInAnyRecipes_CollectionTitle_Text}"
               IsVisible="{Binding RecipesUsingIngredient.Count, Converter={StaticResource IsCountZeroConverter}}"/> 
        
        <CollectionView ItemsSource="{Binding RecipesUsingIngredient}"
                        VerticalOptions="Fill"
                        ItemsLayout="HorizontalList"
                        IsVisible="{Binding RecipesUsingIngredient.Count, Converter={StaticResource IsCountNotZeroConverter}}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:RecipeListResponse">
                        <Border Padding="0"
                                WidthRequest="300" HeightRequest="200">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={x:Reference IngredientDetailViewRoot}, Path=BindingContext.GoToRecipeDetailCommand}"
                                                      CommandParameter="{Binding Id}" />
                            </Border.GestureRecognizers>

                            <Grid>
                                <Image Grid.Row="0"
                                       HorizontalOptions="Fill" VerticalOptions="Fill"
                                       Aspect="AspectFill"
                                       WidthRequest="320" HeightRequest="240"
                                       Source="{Binding ImageUrl.Value, TargetNullValue='recipe_placeholder.jpg'}" />

                                <BoxView Grid.Row="0"
                                         Opacity="0.25"
                                         Color="Black" />

                                <Label Grid.Row="0"
                                       Margin="22,12"
                                       FontSize="20" LineBreakMode="WordWrap"
                                       Text="{Binding Name.Value}"
                                       TextColor="White" VerticalOptions="End" />
                            </Grid>
                        </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
    </VerticalStackLayout>
</views:ContentPageBase>
