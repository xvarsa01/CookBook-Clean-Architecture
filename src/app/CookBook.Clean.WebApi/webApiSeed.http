@host=http://localhost
@port=5003

### INGREDIENTS

### Sugar (with image + description)
POST {{host}}:{{port}}/ingredient
Content-Type: application/json

{
  "Name": "Sugar",
  "Description": "fine white sugar commonly used as a sweetener",
  "ImageUrl": "https://upload.wikimedia.org/wikipedia/commons/8/87/Sugar_cubes.jpg"
}
> {% client.global.set("ing1", response.body); %}

