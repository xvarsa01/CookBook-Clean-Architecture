<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:texts="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Resources.Texts"
             xmlns:inputKit="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
             x:Class="CookBook.CleanArch.Presentation.MauiApplication.Controls.SortDirectionControl"
             x:Name="Root">
    
    <VerticalStackLayout Spacing="10">
        <Label FontSize="12"
               Text="{x:Static texts:ControlTexts.SortDirection_Title_Text}" />
        <inputKit:RadioButtonGroupView>
            <inputKit:RadioButton IsChecked="{Binding Source={x:Reference Root}, Path=IsSortAscending}"
                                  Text="{x:Static texts:ControlTexts.Sort_AscOption_Text}" />
            <inputKit:RadioButton IsChecked="{Binding Source={x:Reference Root}, Path=IsSortAscending, Converter={StaticResource InverseBooleanConverter}}"
                                  Text="{x:Static texts:ControlTexts.Sort_DescOption_Text}"
                                  TextColor="{DynamicResource PrimaryLabelTextColor}" />
        </inputKit:RadioButtonGroupView>
    </VerticalStackLayout>
</ContentView>
