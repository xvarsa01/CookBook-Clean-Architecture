<?xml version="1.0" encoding="utf-8" ?>
<views:ContentPageBase xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                       xmlns:views="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Views"
                       xmlns:xaml="clr-namespace:Microsoft.Maui.Controls.Xaml;assembly=Microsoft.Maui.Controls.Xaml"
                       xmlns:texts="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Resources.Texts"
                       xmlns:viewModels="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.ViewModels"
                       xmlns:models="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Models"
                       x:Class="CookBook.CleanArch.Presentation.MauiApplication.Views.Ingredient.IngredientListView"
                       Title="{xaml:Static texts:IngredientListViewTexts.Page_Title}"
                       Style="{StaticResource ContentPageStyle}"
                       x:Name="IngredientListViewRoot"
                       x:DataType="viewModels:IngredientListViewModel">
    <Grid HorizontalOptions="Fill" RowDefinitions="Auto, *, Auto, Auto"
          RowSpacing="20">
        
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto"
              RowDefinitions="Auto,Auto"
              ColumnSpacing="10"
              RowSpacing="6">

            <!-- Title -->
            <Label Grid.Row="0" Grid.Column="0"
                   Text="{x:Static texts:IngredientListViewTexts.Title_Label}"
                   FontSize="24"
                   VerticalOptions="Center" />

            <!-- Search -->
            <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                <Label Text="Name" FontSize="12" />
                <SearchBar Text="{Binding Filter.Name}"
                           Placeholder="Search ingredient..." />
            </VerticalStackLayout>
            
            <VerticalStackLayout Grid.Row="0" Grid.Column="2"
                                 HorizontalOptions="Center">
                <Label Text="Image" FontSize="12" HorizontalOptions="Center"/>
                <Picker SelectedItem="{Binding Filter.HasImage, Converter={StaticResource NullableBoolToStringConverter}}">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>-</x:String>
                            <x:String>Yes</x:String>
                            <x:String>No</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="0" Grid.Column="3"
                                 HorizontalOptions="Center">
                <Label Text="Description" FontSize="12" HorizontalOptions="Center"/>
                <Picker SelectedItem="{Binding Filter.HasDescription, Converter={StaticResource NullableBoolToStringConverter}}">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>-</x:String>
                            <x:String>Yes</x:String>
                            <x:String>No</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </VerticalStackLayout>
            

            <!-- ~1~ Sorting @1@ -->
            <!-- <VerticalStackLayout Grid.Row="0" Grid.Column="4"> -->
            <!--     <Label Text="Sort by" FontSize="12"/> -->
            <!--     <Picker ItemsSource="{Binding SortOptions}" -->
            <!--             SelectedItem="{Binding Filter.SortParameter}" /> -->
            <!-- </VerticalStackLayout> -->

            <!-- Sort direction -->
            <VerticalStackLayout Grid.Row="0" Grid.Column="5"
                                 HorizontalOptions="Center">
                <Label Text="Asc" FontSize="12" HorizontalOptions="Center"/>
                <Switch IsToggled="{Binding Filter.IsSortAscending}" />
            </VerticalStackLayout>

            <!-- Buttons row -->
            <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="6"
                                   Spacing="10"
                                   HorizontalOptions="End">

                <Button Text="Apply"
                        Command="{Binding ApplyFilterCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </HorizontalStackLayout>
        </Grid>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Ingredients}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Horizontal"
                                 HorizontalItemSpacing="10" VerticalItemSpacing="10"
                                 Span="2" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:IngredientListModel">
                    <Border Style="{StaticResource ImageBorderStyle}"
                            HeightRequest="200">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:Reference IngredientListViewRoot}, Path=BindingContext.GoToDetailCommand}"
                                                  CommandParameter="{Binding Id }" />
                        </Border.GestureRecognizers>
                        
                        <Grid RowDefinitions="*, *">
                            <Image Grid.Row="0" Grid.RowSpan="2"
                                   Aspect="AspectFill"
                                   WidthRequest="200" HeightRequest="200"
                                   Source="{Binding ImageUrl, TargetNullValue='ingredient_placeholder.jpg'}" />

                            <BoxView Grid.Row="0" Grid.RowSpan="2"
                                     Opacity="0.25"
                                     Color="Black" />

                            <Label Grid.Row="1"
                                   Margin="22,12"
                                   FontSize="20" LineBreakMode="WordWrap"
                                   Text="{Binding Name}"
                                   TextColor="White" VerticalOptions="End" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <VerticalStackLayout Grid.Row="2" Spacing="10">
            <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                <Button Command="{Binding ToFirstPageCommand}"
                        Text="⏮" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>

                <Button Command="{Binding ToPreviousPageCommand}"
                        Text="◀" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
        
                <!-- Page numbers -->
                <CollectionView ItemsSource="{Binding PageNumbers}"
                                SelectionMode="None"
                                VerticalOptions="Center">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:PageNumberModel">
                            <Button Text="{Binding Number}"
                                    Command="{Binding Source={x:Reference IngredientListViewRoot}, Path=BindingContext.GoToPageCommand}"
                                    CommandParameter="{Binding Number}"
                                    BackgroundColor="{Binding IsCurrent, Converter={StaticResource BoolToColorConverter}}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Command="{Binding ToNextPageCommand}"
                        Text="▶" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>

                <Button Command="{Binding ToLastPageCommand}"
                        Text="⏭" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <Button Grid.Row="3"
                Text="{x:Static texts:IngredientListViewTexts.Add_Button_Text}"
                Command="{Binding GoToCreateCommand}"
                Style="{StaticResource PrimaryButtonStyle}" />
    </Grid>
</views:ContentPageBase>
