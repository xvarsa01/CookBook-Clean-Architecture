<?xml version="1.0" encoding="utf-8" ?>
<views:ContentPageBase xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                       xmlns:views="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Views"
                       xmlns:xaml="clr-namespace:Microsoft.Maui.Controls.Xaml;assembly=Microsoft.Maui.Controls.Xaml"
                       xmlns:t="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.Resources.Texts"
                       xmlns:viewModels="clr-namespace:CookBook.CleanArch.Presentation.MauiApplication.ViewModels"
                       xmlns:models="using:CookBook.CleanArch.Presentation.MauiApplication.Models"
                       xmlns:controls="using:InputKit.Shared.Controls"
                       xmlns:recipeEnums="clr-namespace:CookBook.CleanArch.Domain.Recipe.Enums;assembly=CookBook.CleanArch.Domain"
                       x:Class="CookBook.CleanArch.Presentation.MauiApplication.Views.Recipe.RecipeListView"
                       Title="{xaml:Static t:RecipeListViewTexts.Page_Title}"
                       x:DataType="viewModels:RecipeListViewModel"
                       x:Name="RecipeListViewRoot"
                       Style="{StaticResource ContentPageStyle}">
    <Grid HorizontalOptions="Fill"
          RowDefinitions="Auto, *, Auto"
          RowSpacing="20"
          Margin="{OnIdiom Phone='10, 0'}">
        
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto, *, Auto">

            <!--  Title  -->
            <Label Grid.Column="0"
                   FontSize="24"
                   Text="{x:Static t:RecipeListViewTexts.Title_Label}" />

            <HorizontalStackLayout Grid.Column="2" Spacing="20">

                <!--  Search  -->
                <VerticalStackLayout WidthRequest="250">
                    <Label FontSize="12"
                           Text="Name" />
                    <SearchBar Placeholder="Search recipe..."
                               Text="{Binding Filter.Name}" />
                </VerticalStackLayout>

                <VerticalStackLayout HorizontalOptions="Center">
                    <Label FontSize="12"
                           HorizontalOptions="Center"
                           Text="Type" />
                    <Picker SelectedItem="{Binding Filter.RecipeType}">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type recipeEnums:RecipeType}">
                                <recipeEnums:RecipeType>None</recipeEnums:RecipeType>
                                <recipeEnums:RecipeType>MainDish</recipeEnums:RecipeType>
                                <recipeEnums:RecipeType>Soup</recipeEnums:RecipeType>
                                <recipeEnums:RecipeType>Dessert</recipeEnums:RecipeType>
                                <recipeEnums:RecipeType>Drink</recipeEnums:RecipeType>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>

                <VerticalStackLayout>
                    <Label FontSize="12"
                           Text="Sort direction" />
                    <controls:RadioButtonGroupView>
                        <controls:RadioButton IsChecked="{Binding Filter.IsSortAscending}"
                                              Text="Ascending" />
                        <controls:RadioButton IsChecked="{Binding Filter.IsSortAscending, Converter={StaticResource InverseBooleanConverter}}"
                                              Text="Descending"
                                              TextColor="{DynamicResource PrimaryLabelTextColor}" />
                    </controls:RadioButtonGroupView>
                </VerticalStackLayout>

                <VerticalStackLayout>
                    <Label Text="Page size" />
                    <controls:RadioButtonGroupView SelectedItem="{Binding PagingOptions.PageSize, Mode=TwoWay}">
                        <controls:RadioButton Text="5"
                                              Value="{x:Int32 5}" />
                        <controls:RadioButton Text="10"
                                              Value="{x:Int32 10}" />
                        <controls:RadioButton Text="15"
                                              Value="{x:Int32 15}" />
                    </controls:RadioButtonGroupView>
                </VerticalStackLayout>

                <Button Margin="10,0"
                        Padding="12,6"
                        Command="{Binding ApplyFilterCommand}"
                        CornerRadius="5"
                        FontFamily="MontserratMedium"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Text="Apply filters"
                        VerticalOptions="Start" />
            </HorizontalStackLayout>
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Recipes}"
                        VerticalOptions="Fill">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Horizontal"
                                 HorizontalItemSpacing="10" VerticalItemSpacing="10"
                                 Span="2" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:RecipeListModel">
                    <Border Padding="0"
                            WidthRequest="300" HeightRequest="200">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:Reference RecipeListViewRoot}, Path=BindingContext.GoToDetailCommand}"
                                                  CommandParameter="{Binding Id}" />
                        </Border.GestureRecognizers>

                        <Grid>
                            <Image Grid.Row="0"
                                   HorizontalOptions="Fill" VerticalOptions="Fill"
                                   Aspect="AspectFill"
                                   WidthRequest="320" HeightRequest="240"
                                   Source="{Binding ImageUrl, TargetNullValue='recipe_placeholder.jpg'}" />

                            <BoxView Grid.Row="0"
                                     Opacity="0.25"
                                     Color="Black" />

                            <Border Grid.Row="0"
                                    Margin="22" Padding="6,0"
                                    BackgroundColor="{Binding RecipeType, Converter={StaticResource FoodTypeToColorConverter}}"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Start"
                                    HeightRequest="20">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="5"/>
                                </Border.StrokeShape>
                                
                                <HorizontalStackLayout Padding="0"
                                                       HorizontalOptions="Start" VerticalOptions="Center"
                                                       Spacing="8">
                                    <Label VerticalOptions="Center"
                                           FontSize="11"
                                           Text="{Binding RecipeType, Converter={StaticResource FoodTypeToStringConverter}}"
                                           TextColor="White" />
                                </HorizontalStackLayout>
                            </Border>

                            <Label Grid.Row="0"
                                   Margin="22,12"
                                   FontSize="20" LineBreakMode="WordWrap"
                                   Text="{Binding Name}"
                                   TextColor="White" VerticalOptions="End" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <Grid Grid.Row="2">
            <Button Grid.Row="0"
                    Padding="12, 6"
                    HorizontalOptions="End" VerticalOptions="Start"
                    Text="{x:Static t:RecipeListViewTexts.Add_Button_Text}"
                    Command="{Binding GoToCreateCommand}"
                    CornerRadius="5" FontFamily="MontserratMedium"
                    FontSize="14"
                    Style="{StaticResource PrimaryButtonStyle}"
                    WidthRequest="200" />

            <HorizontalStackLayout Spacing="5"
                                   HorizontalOptions="Center">
                <Button Command="{Binding ToFirstPageCommand}"
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="⏮"
                        VerticalOptions="Center" />

                <Button Command="{Binding ToPreviousPageCommand}"
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="◀"
                        VerticalOptions="Center" />

                <!--  Page numbers  -->
                <CollectionView ItemsSource="{Binding PageNumbers}"
                                SelectionMode="None"
                                VerticalOptions="Center">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:PageItem">
                            <Button
                                Command="{Binding Source={x:Reference RecipeListViewRoot}, Path=BindingContext.GoToPageCommand}"
                                CommandParameter="{Binding Number}"
                                Text="{Binding Number}">
                                <Button.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrent}"
                                                 TargetType="Button"
                                                 Value="True">
                                        <Setter Property="BackgroundColor" Value="LightGray" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Command="{Binding ToNextPageCommand}"
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="▶"
                        VerticalOptions="Center" />

                <Button Command="{Binding ToLastPageCommand}"
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="⏭"
                        VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Grid>
    </Grid>
</views:ContentPageBase>
